# Server-side only. Never exposed to the browser; the client receives a
# short-lived ephemeral secret minted by /api/realtime/token.
OPENAI_API_KEY=sk-...

# Optional overrides
# OPENAI_REALTIME_MODEL=gpt-realtime
# NIMBUS_SESSION_SECONDS=180        # hard cap per call
# NIMBUS_DAILY_SESSION_CAP=60       # global sessions/day before demo sleeps
# NIMBUS_PER_IP_DAILY_CAP=6         # sessions per IP per day
